---
import { getCollection, render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';

export async function getStaticPaths() {
  const allSummaries = await getCollection('summaries');

  // Build a sorted book list per series for "Next Book" navigation
  const seriesBooksMap: Record<string, { bookName: string; bookSlug: string; bookOrder: number }[]> = {};
  allSummaries.forEach(chunk => {
    const sSlug = chunk.data.series.toLowerCase().replace(/\s+/g, '-');
    const bSlug = chunk.data.book.toLowerCase().replace(/\s+/g, '-');
    if (!seriesBooksMap[sSlug]) seriesBooksMap[sSlug] = [];
    if (!seriesBooksMap[sSlug].find(b => b.bookSlug === bSlug)) {
      seriesBooksMap[sSlug].push({ bookName: chunk.data.book, bookSlug: bSlug, bookOrder: chunk.data.bookOrder ?? 99 });
    }
  });
  Object.values(seriesBooksMap).forEach(books => books.sort((a, b) => a.bookOrder - b.bookOrder));

  // Group all chunks by their Series and Book
  const grouped = allSummaries.reduce((acc, chunk) => {
    const key = `${chunk.data.series}|${chunk.data.book}`;
    if (!acc[key]) acc[key] = [];
    acc[key].push(chunk);
    return acc;
  }, {} as Record<string, typeof allSummaries>);

  const paths = [];

  for (const [key, chunks] of Object.entries(grouped)) {
    const seriesData = chunks[0].data.series;
    const bookData   = chunks[0].data.book;
    const seriesSlug = seriesData.toLowerCase().replace(/\s+/g, '-');
    const bookSlug   = bookData.toLowerCase().replace(/\s+/g, '-');

    chunks.sort((a, b) => a.data.startChapter - b.data.startChapter);

    const bookUrl = `/${seriesSlug}/${bookSlug}`;

    // Determine next book in series (used only on the final chunk)
    const seriesBooks   = seriesBooksMap[seriesSlug] ?? [];
    const currentBookIdx = seriesBooks.findIndex(b => b.bookSlug === bookSlug);
    const nextBookData  = currentBookIdx >= 0 && currentBookIdx < seriesBooks.length - 1
      ? seriesBooks[currentBookIdx + 1]
      : null;

    for (let i = 0; i < chunks.length; i++) {
      const currentChunk = chunks[i];
      const prevChunk    = i > 0 ? chunks[i - 1] : null;
      const nextChunk    = i < chunks.length - 1 ? chunks[i + 1] : null;
      const isLastChunk  = i === chunks.length - 1;

      paths.push({
        params: { series: seriesSlug, book: bookSlug, range: currentChunk.data.range },
        props: {
          seriesName: seriesData,
          bookName: bookData,
          range: currentChunk.data.range,
          chunk: currentChunk,
          bookUrl,
          prevUrl:      prevChunk ? `${bookUrl}/${prevChunk.data.range}` : null,
          nextUrl:      nextChunk ? `${bookUrl}/${nextChunk.data.range}` : null,
          prevRange:    prevChunk ? prevChunk.data.range : null,
          nextRange:    nextChunk ? nextChunk.data.range : null,
          nextBookName: isLastChunk && nextBookData ? nextBookData.bookName : null,
          nextBookUrl:  isLastChunk && nextBookData ? `/${seriesSlug}/${nextBookData.bookSlug}` : null,
        },
      });
    }
  }

  return paths;
}

const { seriesName, bookName, range, chunk, bookUrl, prevUrl, nextUrl, prevRange, nextRange, nextBookName, nextBookUrl } = Astro.props;
const seriesSlug = Astro.params.series;
const bookSlug = Astro.params.book;

const { Content } = await render(chunk);

const pageTitle = `${bookName} recap chapters ${range} | The Lorebrary`;
const pageDescription = `Lorebrary recap of ${bookName} chapters ${range}. A concrete narrative refresher of plot points and actions from the ${seriesName} series before you read the sequel.`;
---

<Layout title={pageTitle} description={pageDescription} ogType="article">
  <!-- Reading Progress Bar -->
  <div id="reading-progress" class="fixed top-0 left-0 h-[3px] bg-gold-400 z-[60] pointer-events-none" style="width:0%"></div>

  <!-- Floating Chapter Banner -->
  <div id="chapter-banner" class="fixed top-0 left-0 right-0 z-[55] pt-[3px] pointer-events-none opacity-0 transition-opacity duration-300">
    <div class="flex items-center justify-center gap-2 py-1.5 bg-ink-950/85 backdrop-blur-sm border-b border-gold-400/15">
      <svg class="w-2.5 h-2.5 text-gold-400/70 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"/>
      </svg>
      <span id="chapter-banner-text" class="text-[14px] font-bold font-display tracking-[0.18em] uppercase text-gold-400 truncate max-w-[80vw]"></span>
    </div>
  </div>

  <div class="max-w-3xl mx-auto py-12 px-4 sm:px-6">

    <!-- Header -->
    <div id="page-header" class="mb-16 border-b border-cream-200 dark:border-ink-700 pb-10 transition-colors duration-300">
      <Breadcrumb items={[
        { label: 'Archive', href: '/archive' },
        { label: seriesName, href: `/${seriesSlug}` },
        { label: bookName, href: bookUrl },
        { label: `Ch. ${range}` }
      ]} />
      <p class="text-sm font-bold text-cream-500 dark:text-gold-400/70 mb-1 uppercase tracking-[0.15em] transition-colors duration-300">{seriesName}</p>
      <h1 class="text-4xl sm:text-5xl font-display font-semibold text-cream-900 dark:text-cream-100 tracking-wide mb-6 transition-colors duration-300">{bookName}</h1>
      <div class="flex items-center gap-3 flex-wrap">
        <div class="inline-flex items-center gap-2 bg-ink-800 dark:bg-ink-800 border border-gold-400/40 text-gold-400 px-4 py-1.5 rounded text-xs font-bold tracking-[0.18em] uppercase">
          <svg class="w-3 h-3 opacity-70" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"/>
          </svg>
          Chapters {range}
        </div>
        <button
          id="share-btn"
          class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded border border-cream-300 dark:border-ink-600 bg-cream-50 dark:bg-ink-800 text-cream-500 dark:text-cream-500 hover:border-gold-400 hover:text-gold-600 dark:hover:text-gold-400 transition-all duration-200 text-xs font-bold tracking-[0.12em] uppercase"
        >
          <svg id="share-icon" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
          </svg>
          <span id="share-label">Copy Link</span>
        </button>
      </div>
    </div>

    <!-- The Content -->
    <div class="space-y-24">
      <article class="prose prose-lg dark:prose-invert max-w-none prose-p:leading-[1.95] prose-p:indent-8 prose-p:mb-6 transition-colors duration-300">
        <Content />
      </article>
    </div>

    <!-- Pagination -->
    <div class="mt-20 pt-8 border-t border-cream-200 dark:border-ink-700 flex flex-col sm:flex-row items-center justify-between gap-4 transition-colors duration-300">
      {prevUrl ? (
        <a href={prevUrl} class="w-full sm:w-auto px-6 py-4 bg-cream-50 dark:bg-ink-800 border border-cream-300 dark:border-ink-700 rounded-lg hover:border-gold-400 dark:hover:border-gold-400 hover:shadow-[0_4px_20px_rgba(201,168,76,0.08)] transition-all duration-200 group flex items-center justify-start sm:justify-center">
          <svg class="w-5 h-5 mr-3 text-cream-500 dark:text-cream-500 group-hover:text-gold-500 dark:group-hover:text-gold-400 group-hover:-translate-x-1 transition-all duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          <div class="text-left">
            <span class="block text-xs text-cream-500 dark:text-cream-500 uppercase tracking-[0.12em] mb-0.5">Previous</span>
            <span class="block text-sm font-bold font-display text-cream-900 dark:text-cream-100 group-hover:text-gold-600 dark:group-hover:text-gold-400 transition-colors duration-200">Chapters {prevRange}</span>
          </div>
        </a>
      ) : <div class="hidden sm:block"></div>}

      {nextUrl ? (
        <a href={nextUrl} class="w-full sm:w-auto px-6 py-4 bg-cream-50 dark:bg-ink-800 border border-cream-300 dark:border-ink-700 rounded-lg hover:border-gold-400 dark:hover:border-gold-400 hover:shadow-[0_4px_20px_rgba(201,168,76,0.08)] transition-all duration-200 group flex items-center justify-end sm:justify-center ml-auto">
          <div class="text-right">
            <span class="block text-xs text-cream-500 dark:text-cream-500 uppercase tracking-[0.12em] mb-0.5">Next</span>
            <span class="block text-sm font-bold font-display text-cream-900 dark:text-cream-100 group-hover:text-gold-600 dark:group-hover:text-gold-400 transition-colors duration-200">Chapters {nextRange}</span>
          </div>
          <svg class="w-5 h-5 ml-3 text-cream-500 dark:text-cream-500 group-hover:text-gold-500 dark:group-hover:text-gold-400 group-hover:translate-x-1 transition-all duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      ) : <div class="hidden sm:block"></div>}
    </div>

    <!-- Next Book card — only appears on the final chunk of a book -->
    {nextBookName && nextBookUrl && (
      <div class="mt-12 pt-10 border-t border-cream-200 dark:border-ink-700">
        <p class="text-xs font-bold text-cream-500 dark:text-cream-500 uppercase tracking-[0.18em] mb-4 text-center">You've finished this book</p>
        <a
          href={nextBookUrl}
          class="flex items-center justify-between w-full px-6 py-5 bg-cream-50 dark:bg-ink-800 border border-gold-400/40 dark:border-gold-400/30 rounded-xl hover:border-gold-400 dark:hover:border-gold-400 hover:shadow-[0_4px_28px_rgba(201,168,76,0.14)] transition-all duration-200 group"
        >
          <div>
            <div class="text-[10px] font-bold uppercase tracking-[0.18em] text-cream-500 dark:text-cream-500 mb-1">Up Next in {seriesName}</div>
            <div class="text-xl font-display font-semibold text-cream-900 dark:text-cream-100 group-hover:text-gold-600 dark:group-hover:text-gold-400 transition-colors duration-200">
              {nextBookName}
            </div>
          </div>
          <svg class="w-6 h-6 text-cream-500 dark:text-cream-500 group-hover:text-gold-400 group-hover:translate-x-1 transition-all duration-200 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </div>
    )}

  </div>

<script define:vars={{ seriesSlug, bookSlug, range, nextUrl, bookName, seriesName }}>
  try {
    localStorage.setItem(`distiller_read_${seriesSlug}_${bookSlug}_${range}`, 'true');
    localStorage.setItem(`distiller_progress_${seriesSlug}_${bookSlug}`, JSON.stringify({
      range,
      currentUrl: window.location.pathname,
      nextUrl: nextUrl || null,
      bookName,
      seriesName,
      timestamp: Date.now()
    }));
  } catch (e) {}
</script>

<script>
  const shareBtn = document.getElementById('share-btn');
  const shareLabel = document.getElementById('share-label');
  const shareIcon = document.getElementById('share-icon');
  if (shareBtn && shareLabel && shareIcon) {
    shareBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        shareLabel.textContent = 'Copied!';
        shareIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />';
        shareBtn.classList.add('border-gold-400', 'text-gold-500', 'dark:text-gold-400');
        setTimeout(() => {
          shareLabel.textContent = 'Copy Link';
          shareIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />';
          shareBtn.classList.remove('border-gold-400', 'text-gold-500', 'dark:text-gold-400');
        }, 2000);
      } catch (e) {}
    });
  }
</script>

<script define:vars={{ prevUrl, nextUrl }}>
  // Reading progress bar
  const bar = document.getElementById('reading-progress');
  if (bar) {
    function updateBar() {
      const scrolled = window.scrollY;
      const total = document.documentElement.scrollHeight - window.innerHeight;
      bar.style.width = (total > 0 ? (scrolled / total) * 100 : 0) + '%';
    }
    window.addEventListener('scroll', updateBar, { passive: true });
    updateBar();
  }

  // Keyboard navigation (← prev, → next)
  document.addEventListener('keydown', (e) => {
    const tag = document.activeElement?.tagName;
    if (tag === 'INPUT' || tag === 'TEXTAREA') return;
    if (e.key === 'ArrowLeft' && prevUrl) window.location.href = prevUrl;
    if (e.key === 'ArrowRight' && nextUrl) window.location.href = nextUrl;
  });
</script>

<script>
  // Floating chapter banner
  const banner = document.getElementById('chapter-banner');
  const bannerText = document.getElementById('chapter-banner-text');
  const pageHeader = document.getElementById('page-header');

  if (banner && bannerText && pageHeader) {
    // Show/hide banner based on whether the page header is visible
    const headerObserver = new IntersectionObserver(
      ([entry]) => {
        banner.style.opacity = entry.isIntersecting ? '0' : '1';
      },
      { threshold: 0 }
    );
    headerObserver.observe(pageHeader);

    // Track which h3 heading is currently at the top of the viewport
    const headings = document.querySelectorAll('article h3');
    if (headings.length) {
      const headingObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              bannerText.textContent = entry.target.textContent || '';
            }
          });
        },
        { rootMargin: '-5% 0px -85% 0px', threshold: 0 }
      );
      headings.forEach(h => headingObserver.observe(h));
      // Pre-populate with first heading
      bannerText.textContent = headings[0].textContent || '';
    }
  }
</script>

</Layout>

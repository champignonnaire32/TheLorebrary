---
import { getCollection, render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';

export async function getStaticPaths() {
  const allSummaries = await getCollection('summaries');

  // Build sorted book list per series for "Next Book" navigation
  const seriesBooksMap: Record<string, { bookName: string; bookSlug: string; bookOrder: number }[]> = {};
  allSummaries.forEach(chunk => {
    const sSlug = chunk.data.series.toLowerCase().replace(/\s+/g, '-');
    const bSlug = chunk.data.book.toLowerCase().replace(/\s+/g, '-');
    if (!seriesBooksMap[sSlug]) seriesBooksMap[sSlug] = [];
    if (!seriesBooksMap[sSlug].find(b => b.bookSlug === bSlug)) {
      seriesBooksMap[sSlug].push({ bookName: chunk.data.book, bookSlug: bSlug, bookOrder: chunk.data.bookOrder ?? 99 });
    }
  });
  Object.values(seriesBooksMap).forEach(books => books.sort((a, b) => a.bookOrder - b.bookOrder));

  const grouped = allSummaries.reduce((acc, chunk) => {
    const key = `${chunk.data.series}|${chunk.data.book}`;
    if (!acc[key]) acc[key] = [];
    acc[key].push(chunk);
    return acc;
  }, {} as Record<string, typeof allSummaries>);

  const paths = [];

  for (const [key, chunks] of Object.entries(grouped)) {
    const seriesData = chunks[0].data.series;
    const bookData  = chunks[0].data.book;
    const seriesSlug = seriesData.toLowerCase().replace(/\s+/g, '-');
    const bookSlug   = bookData.toLowerCase().replace(/\s+/g, '-');

    chunks.sort((a, b) => a.data.startChapter - b.data.startChapter);

    const totalChaptersCount = chunks.reduce((count, chunk) => {
      const chapterMatches = chunk.body.match(/^###\s+/gm);
      return count + (chapterMatches ? chapterMatches.length : 0);
    }, 0);

    const seriesBooks    = seriesBooksMap[seriesSlug] ?? [];
    const currentBookIdx = seriesBooks.findIndex(b => b.bookSlug === bookSlug);
    const nextBookData   = currentBookIdx >= 0 && currentBookIdx < seriesBooks.length - 1
      ? seriesBooks[currentBookIdx + 1]
      : null;

    paths.push({
      params: { series: seriesSlug, book: bookSlug },
      props: {
        seriesName: seriesData,
        bookName: bookData,
        chunks,
        totalChapters: totalChaptersCount,
        nextBookName: nextBookData?.bookName ?? null,
        nextBookUrl:  nextBookData ? `/${seriesSlug}/${nextBookData.bookSlug}` : null,
      },
    });
  }

  return paths;
}

const { seriesName, bookName, chunks, totalChapters, nextBookName, nextBookUrl } = Astro.props;
const seriesSlug = Astro.params.series;
const bookSlug   = Astro.params.book;
const bookUrl    = `/${seriesSlug}/${bookSlug}`;

// Render every chunk's markdown at build time
const renderedChunks = await Promise.all(
  chunks.map(async (chunk) => {
    const { Content } = await render(chunk);
    return { range: chunk.data.range, Content };
  })
);

const ranges = renderedChunks.map(c => c.range);

const pageTitle       = `${bookName} — Full Recap | The Lorebrary`;
const pageDescription = `Complete narrative refresher for ${bookName}. All ${totalChapters} chapter recaps in a single continuous read — ${seriesName} series.`;
---

<Layout title={pageTitle} description={pageDescription} ogType="article">

  <!-- Reading Progress Bar -->
  <div id="reading-progress" class="fixed top-0 left-0 h-[3px] bg-gold-400 z-[60] pointer-events-none" style="width:0%"></div>

  <!-- Floating Chapter Banner -->
  <div id="chapter-banner" class="fixed top-0 left-0 right-0 z-[55] pt-[3px] pointer-events-none opacity-0 transition-opacity duration-300">
    <div class="flex items-center justify-center gap-2 py-1.5 bg-ink-950/85 backdrop-blur-sm border-b border-gold-400/15">
      <svg class="w-2.5 h-2.5 text-gold-400/70 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"/>
      </svg>
      <span id="chapter-banner-text" class="text-[18px] font-bold font-display tracking-[0.18em] uppercase text-gold-400 truncate max-w-[80vw]"></span>
    </div>
  </div>

  <!-- Floating Chapter Jump Nav (xl screens only) -->
  <aside
    id="chapter-nav"
    class="hidden xl:block fixed top-1/2 right-6 -translate-y-1/2 z-40 max-h-[70vh] overflow-y-auto"
    aria-label="Jump to chapter range"
  >
    <p class="text-[10px] font-bold uppercase tracking-[0.18em] text-cream-500 dark:text-cream-500 mb-2 px-2">Jump To</p>
    <nav class="flex flex-col gap-0.5">
      {ranges.map(range => (
        <button
          class="chapter-jump-btn group flex items-center gap-3 px-3 py-1.5 rounded-md hover:bg-ink-800 transition-all duration-200 text-left border border-transparent hover:border-gold-400/20"
          data-target-range={range}
        >
          <span class="text-[11px] font-bold tracking-widest text-cream-600 dark:text-cream-500 group-hover:text-gold-400">
            {range}
          </span>
        </button>
      ))}
    </nav>
  </aside>

  <div class="max-w-4xl mx-auto py-12 px-4 sm:px-6">

    <div class="mb-16">
      <Breadcrumb items={[
        { label: 'Archive',    href: '/archive' },
        { label: seriesName,   href: `/${seriesSlug}` },
        { label: bookName,     href: bookUrl },
        { label: 'Full Recap' },
      ]} />
      <p class="text-sm font-bold text-cream-500 dark:text-gold-400/70 mb-1 uppercase tracking-[0.15em]">{seriesName}</p>
      <h1 class="text-4xl sm:text-5xl font-display font-semibold text-cream-900 dark:text-cream-100 tracking-wide mb-5">{bookName}</h1>
      <div class="flex flex-wrap items-center gap-3">
        <div class="inline-flex items-center gap-2 bg-ink-800 border border-gold-400/40 text-gold-400 px-4 py-1.5 rounded text-xs font-bold tracking-[0.15em] uppercase">
          <svg class="w-3.5 h-3.5 opacity-80" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"/>
          </svg>
          Full Recap — {totalChapters} Chapters
        </div>
      </div>
    </div>

    <!-- All chunks rendered in sequence -->
    <div class="space-y-20">
      {renderedChunks.map(({ range, Content }) => (
        <section id={`range-${range}`} data-range-section={range} class="scroll-mt-6">

          <!-- Chapter range divider header -->
          <div class="flex items-center gap-4 mb-8 opacity-40 group-hover:opacity-100 transition-opacity duration-300">
            <div class="h-px flex-1 bg-gradient-to-r from-transparent to-gold-400/50"></div>
            <span class="text-[10px] font-bold tracking-[0.3em] uppercase text-gold-500/80">Range {range}</span>
            <div class="h-px flex-1 bg-gradient-to-l from-transparent to-gold-400/50"></div>
          </div>

          <div class="prose prose-lg prose-cream dark:prose-invert max-w-none
            prose-headings:font-display prose-headings:font-semibold prose-headings:tracking-tight
            prose-h3:text-2xl prose-h3:mt-0 prose-h3:mb-6 prose-h3:text-gold-600 dark:prose-h3:text-gold-400
            prose-p:text-cream-700 dark:prose-p:text-cream-200 prose-p:leading-relaxed prose-p:mb-8
            prose-strong:text-gold-700 dark:prose-strong:text-gold-300 prose-strong:font-semibold">
            <Content />
          </div>
        </section>
      ))}
    </div>

    <!-- Next Book Navigation -->
    {nextBookUrl && (
      <div class="mt-24 pt-12 border-t border-cream-200 dark:border-ink-700 transition-colors duration-300">
        <p class="text-xs font-bold text-cream-500 dark:text-cream-500 uppercase tracking-[0.2em] mb-4 text-center">Continue the Journey</p>
        <a
          href={nextBookUrl}
          class="group block max-w-xl mx-auto p-8 bg-cream-50 dark:bg-ink-800 border border-gold-400/30 rounded-xl hover:border-gold-400 transition-all duration-300 text-center hover:shadow-[0_8px_32px_rgba(201,168,76,0.12)]"
        >
          <span class="block text-sm text-gold-600 dark:text-gold-400 font-medium mb-1 uppercase tracking-widest">Next Book</span>
          <span class="block text-2xl md:text-3xl font-display font-bold text-cream-900 dark:text-cream-100 group-hover:text-gold-600 dark:group-hover:text-gold-400 transition-colors duration-200 uppercase tracking-tight">{nextBookName}</span>
          <div class="mt-6 flex items-center justify-center gap-2 text-sm font-bold text-cream-500 group-hover:text-gold-500 transition-colors duration-200">
            <span>Read Recaps</span>
            <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </div>
        </a>
      </div>
    )}

    <!-- Back to Top -->
    <div class="mt-20 flex justify-center">
      <button
        id="scroll-to-top"
        class="flex flex-col items-center gap-2 text-cream-400 hover:text-gold-500 transition-colors duration-300 group"
      >
        <div class="w-10 h-10 rounded-full border border-cream-200 dark:border-ink-700 flex items-center justify-center group-hover:border-gold-400 transition-colors duration-300">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
          </svg>
        </div>
        <span class="text-[10px] font-bold uppercase tracking-[0.2em]">Back to Top</span>
      </button>
    </div>

  </div>
</Layout>

<script>
  // Handle Reading Progress
  window.addEventListener('scroll', () => {
    const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
    const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
    const scrolled = (winScroll / height) * 100;
    const bar = document.getElementById('reading-progress');
    if (bar) bar.style.width = scrolled + '%';

    // Handle Floating Chapter Banner
    const banner = document.getElementById('chapter-banner');
    const bannerText = document.getElementById('chapter-banner-text');
    const sections = document.querySelectorAll('[data-range-section]');

    let currentRange = '';
    sections.forEach(section => {
      const rect = section.getBoundingClientRect();
      if (rect.top <= 100) {
        currentRange = section.getAttribute('data-range-section');
      }
    });

    if (banner && bannerText) {
      if (winScroll > 300 && currentRange) {
        banner.style.opacity = '1';
        bannerText.textContent = `Range ${currentRange}`;
      } else {
        banner.style.opacity = '0';
      }
    }
  });

  // Handle Chapter Jump Navigation
  const jumpButtons = document.querySelectorAll('.chapter-jump-btn');
  jumpButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const range = btn.getAttribute('data-target-range');
      const target = document.getElementById(`range-${range}`);
      if (target) {
        target.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });

  // Handle Scroll to Top
  const topBtn = document.getElementById('scroll-to-top');
  if (topBtn) {
    topBtn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>

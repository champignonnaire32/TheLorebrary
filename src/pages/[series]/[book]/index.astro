---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';

export async function getStaticPaths() {
  const allSummaries = await getCollection('summaries');

  // Group all chunks by their Series and Book
  const grouped = allSummaries.reduce((acc, chunk) => {
    const key = `${chunk.data.series}|${chunk.data.book}`;
    if (!acc[key]) acc[key] = [];
    acc[key].push(chunk);
    return acc;
  }, {} as Record<string, typeof allSummaries>);

  const paths = [];

  // Loop through each book
  for (const [key, chunks] of Object.entries(grouped)) {
    const seriesData = chunks[0].data.series;
    const bookData = chunks[0].data.book;

    const seriesSlug = seriesData.toLowerCase().replace(/\s+/g, '-');
    const bookSlug = bookData.toLowerCase().replace(/\s+/g, '-');

    chunks.sort((a, b) => a.data.startChapter - b.data.startChapter);

    const formattedChunks = chunks.map(chunk => ({
      range: chunk.data.range,
      url: `/${seriesSlug}/${bookSlug}/${chunk.data.range}`,
    }));

    paths.push({
      params: { series: seriesSlug, book: bookSlug },
      props: {
        seriesName: seriesData,
        bookName: bookData,
        chunks: formattedChunks
      },
    });
  }

  return paths;
}

const { seriesName, bookName, chunks } = Astro.props;
const seriesSlug = Astro.params.series;
const bookSlug = Astro.params.book;
const pageDescription = `Lorebrary recap index for ${bookName}. Select a chapter range to begin your concrete narrative refresher for the ${seriesName} series.`;

const q = encodeURIComponent(bookName);
const bookshopUrl = `https://bookshop.org/search?keywords=${q}`;
const bnUrl       = `https://www.barnesandnoble.com/s/${q}`;
---

<Layout title={`${bookName} | The Lorebrary`} description={pageDescription}>
  <div class="max-w-4xl mx-auto py-12 px-4 sm:px-6">

    <!-- Header -->
    <div class="mb-16">
      <Breadcrumb items={[
        { label: 'Archive', href: '/archive' },
        { label: seriesName, href: `/${seriesSlug}` },
        { label: bookName }
      ]} />
      <p class="text-sm font-bold text-cream-500 dark:text-gold-400/70 mb-1 uppercase tracking-[0.15em] transition-colors duration-300">{seriesName}</p>
      <h1 class="text-4xl sm:text-5xl font-display font-semibold text-cream-900 dark:text-cream-100 tracking-wide mb-6 transition-colors duration-300">{bookName}</h1>
      <p class="text-lg text-cream-600 dark:text-cream-300 max-w-2xl transition-colors duration-300">
        Pick up where your memory left off.
      </p>
    </div>

    <!-- Mega-Catchup CTA -->
    <a
      href={`/${seriesSlug}/${bookSlug}/full`}
      class="flex items-center gap-4 max-w-xs mx-auto mb-8 px-5 py-4 bg-cream-50 dark:bg-ink-800 border border-gold-400/40 dark:border-gold-400/25 rounded-lg hover:border-gold-400 dark:hover:border-gold-400 hover:shadow-[0_4px_24px_rgba(201,168,76,0.12)] transition-all duration-200 group"
    >
      <div class="w-10 h-10 rounded-lg bg-gold-400/12 dark:bg-gold-400/10 border border-gold-400/30 flex items-center justify-center flex-shrink-0">
        <svg class="w-5 h-5 text-gold-600 dark:text-gold-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
      </div>
      <div class="flex-1 flex flex-col items-center text-center">
        <div class="text-base font-display font-semibold text-cream-900 dark:text-cream-100 group-hover:text-gold-600 dark:group-hover:text-gold-400 transition-colors duration-200">Read Full Recap</div>
        <div class="text-xs text-cream-500 dark:text-cream-500 mt-0.5">All {chunks.length} sections · continuous scroll</div>
      </div>
    </a>

    <!-- Progress indicator (populated by client script) -->
    <div id="progress-indicator" class="hidden mb-4 flex items-center gap-2 text-sm text-cream-500 dark:text-cream-500 transition-colors duration-300">
      <div id="progress-bar-track" class="flex-1 h-1 bg-cream-200 dark:bg-ink-700 rounded-full overflow-hidden">
        <div id="progress-bar-fill" class="h-full bg-gold-400 rounded-full transition-all duration-500" style="width:0%"></div>
      </div>
      <span id="progress-text" class="text-xs font-bold tracking-[0.08em] tabular-nums flex-shrink-0"></span>
    </div>

    <!-- Navigation Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
      {chunks.map(chunk => (
        <a
          href={chunk.url}
          data-range={chunk.range}
          class="block text-center py-6 px-4 bg-cream-50 dark:bg-ink-800 border border-cream-300 dark:border-ink-700 rounded-lg hover:border-gold-400 dark:hover:border-gold-400 hover:shadow-[0_4px_20px_rgba(201,168,76,0.10)] transition-all duration-200 group relative"
        >
          <div class="text-xs text-cream-500 dark:text-cream-500 uppercase tracking-[0.12em] mb-1.5 group-hover:text-gold-600 dark:group-hover:text-gold-400 transition-colors duration-200">Chapters</div>
          <div class="text-2xl font-display font-semibold text-cream-900 dark:text-cream-100 group-hover:text-gold-600 dark:group-hover:text-gold-400 transition-colors duration-200">{chunk.range}</div>
        </a>
      ))}
    </div>

  </div>

  <!-- Get the Book FAB — disabled for now, preserved for potential re-enable -->
  {false && <div id="book-fab-wrap" class="fixed bottom-[28px] left-[28px] z-50 flex flex-col items-start gap-[14px]">

    <!-- Floating card panel -->
    <div
      id="book-panel"
      class="rounded border border-cream-200 dark:border-ink-600/80 bg-cream-50 dark:bg-ink-800 overflow-hidden min-w-[260px] transition-colors duration-300"
      style="display:none; box-shadow: 0 8px 40px rgba(9,15,30,0.7), 0 0 0 1px rgba(201,168,76,0.08);"
    >
      <div class="h-1" style="background: linear-gradient(to right, transparent, rgba(201,168,76,0.6), transparent)"></div>
      <div class="px-6 pt-4 pb-3 border-b border-cream-200/70 dark:border-ink-700 transition-colors duration-300">
        <p class="text-xs font-bold font-display uppercase tracking-[0.2em] text-cream-500 dark:text-cream-500 text-center">Get the Book</p>
      </div>
      <div class="px-6 py-5">
        <div class="flex gap-3 items-stretch mb-3">
          <a
            href={bookshopUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex-1 flex flex-col items-center justify-center gap-0.5 px-5 py-2.5 bg-gold-500 hover:bg-gold-400 dark:bg-gold-400 dark:hover:bg-gold-300 rounded transition-all duration-200 shadow-sm"
          >
            <span class="text-sm font-bold font-display text-ink-950">Bookshop.org</span>
            <span class="text-[10px] uppercase tracking-[0.1em] text-ink-950/60">supports indie bookshops</span>
          </a>
          <a
            href={bnUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex-1 flex items-center justify-center px-5 py-2.5 bg-gold-500 hover:bg-gold-400 dark:bg-gold-400 dark:hover:bg-gold-300 rounded transition-all duration-200 shadow-sm"
          >
            <span class="text-sm font-bold font-display text-ink-950">Barnes &amp; Noble</span>
          </a>
        </div>
        <p class="text-[13px] italic text-cream-500 dark:text-cream-500 text-center">
          Haven't grabbed a copy yet? Also available at your local library or on <a href="https://libbyapp.com" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:text-gold-600 dark:hover:text-gold-400 transition-colors duration-200">Libby</a>.
        </p>
      </div>
    </div>

    <!-- Round FAB -->
    <button
      id="book-fab"
      class="w-[58px] h-[58px] rounded-full flex items-center justify-center transition-all hover:scale-105 active:scale-95 focus:outline-none"
      style="background: #c9a84c; color: #090f1e; box-shadow: 0 4px 20px rgba(201,168,76,0.35);"
      aria-label="Get the Book"
    >
      <span class="text-[8px] font-bold font-display uppercase leading-tight tracking-wide text-center select-none">Get<br/>the Book</span>
    </button>

  </div>}

</Layout>

<script>
  const fab   = document.getElementById('book-fab');
  const panel = document.getElementById('book-panel');
  if (fab && panel) {
    fab.addEventListener('click', e => {
      e.stopPropagation();
      const open = panel.style.display !== 'none';
      panel.style.display = open ? 'none' : 'block';
      fab.style.background = open ? '#c9a84c' : '#b09220';
    });
    document.addEventListener('click', e => {
      if (!panel.contains(e.target as Node) && e.target !== fab) {
        panel.style.display = 'none';
        fab.style.background = '#c9a84c';
      }
    });
  }
</script>

<script define:vars={{ seriesSlug, bookSlug }}>
  try {
    const allChunks = document.querySelectorAll('[data-range]');
    const total = allChunks.length;
    let readCount = 0;

    allChunks.forEach(el => {
      const r = el.dataset.range;
      if (localStorage.getItem(`distiller_read_${seriesSlug}_${bookSlug}_${r}`)) {
        readCount++;
        el.classList.add('chunk-is-read');
        const badge = document.createElement('div');
        badge.style.cssText = [
          'position:absolute', 'top:8px', 'right:8px',
          'width:18px', 'height:18px',
          'background:#c9a84c', 'border-radius:50%',
          'display:flex', 'align-items:center', 'justify-content:center',
          'flex-shrink:0'
        ].join(';');
        badge.innerHTML = '<svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 5l2.5 2.5L8 3" stroke="#090f1e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
        el.appendChild(badge);
      }
    });

    if (readCount > 0) {
      const indicator = document.getElementById('progress-indicator');
      const fill = document.getElementById('progress-bar-fill');
      const text = document.getElementById('progress-text');
      if (indicator && fill && text) {
        indicator.classList.remove('hidden');
        indicator.classList.add('flex');
        fill.style.width = ((readCount / total) * 100) + '%';
        text.textContent = `${readCount} of ${total} read`;
      }
    }
  } catch (e) {}
</script>

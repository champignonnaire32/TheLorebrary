---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { seriesMetadata } from '../../data/series-metadata';

export async function getStaticPaths() {
  const allSummaries = await getCollection('summaries');

  // Group by series
  const grouped = allSummaries.reduce((acc, summary) => {
    const seriesData = summary.data.series;
    if (!acc[seriesData]) acc[seriesData] = new Map();

    const bookData = summary.data.book;
    const bookSlug = bookData.toLowerCase().replace(/\s+/g, '-');
    if (!acc[seriesData].has(bookSlug)) {
      acc[seriesData].set(bookSlug, {
        bookName: bookData,
        bookOrder: summary.data.bookOrder || 99,
        url: `/${seriesData.toLowerCase().replace(/\s+/g, '-')}/${bookSlug}`
      });
    }
    return acc;
  }, {} as Record<string, Map<string, any>>);

  return Object.keys(grouped).map(seriesName => {
    const seriesSlug = seriesName.toLowerCase().replace(/\s+/g, '-');
    const meta = seriesMetadata[seriesName];
    return {
      params: { series: seriesSlug },
      props: {
        seriesName,
        author: meta?.author ?? '',
        blurb: meta?.blurb ?? '',
        books: Array.from(grouped[seriesName].values()).sort((a, b) => a.bookOrder - b.bookOrder)
      },
    };
  });
}

const { seriesName, author, blurb, books } = Astro.props;
const pageDescription = `Access the narrative refreshers for the ${seriesName} series. Choose a book to view its chapter recaps.`;
---

<Layout title={`${seriesName} | The Lorebrary`} description={pageDescription}>
  <div class="max-w-4xl mx-auto py-12 px-4 sm:px-6">
    <div class="mb-16">
      <Breadcrumb items={[
        { label: 'Archive', href: '/archive' },
        { label: seriesName }
      ]} />
      {author && (
        <p class="text-sm font-bold text-cream-500 dark:text-gold-400/70 mb-1 uppercase tracking-[0.15em] transition-colors duration-300">{author}</p>
      )}
      <h1 class="text-4xl md:text-5xl font-display font-semibold mb-6 tracking-wide text-cream-900 dark:text-cream-100 transition-colors duration-300">
        {seriesName}
      </h1>
      {blurb && (
        <p class="text-base text-cream-600 dark:text-cream-300 leading-relaxed max-w-2xl mb-6 transition-colors duration-300">{blurb}</p>
      )}
      <p class="text-sm text-cream-500 dark:text-cream-500 transition-colors duration-300">
        Select a book below to view chapter records.
      </p>
    </div>

    <div class="grid gap-5 md:grid-cols-2">
      {books.map((book: any) => (
        <a
          href={book.url}
          class="block group relative p-6 bg-cream-50 dark:bg-ink-800 rounded-lg border border-cream-300 dark:border-ink-700 hover:border-gold-400 dark:hover:border-gold-400 transition-all duration-200 shadow-sm hover:shadow-[0_4px_24px_rgba(201,168,76,0.10)]"
        >
          <div class="text-xs font-bold text-cream-500 dark:text-cream-500 uppercase tracking-[0.15em] mb-2 transition-colors duration-300">
            Book {book.bookOrder}
          </div>
          <h2 class="text-2xl font-display font-semibold text-cream-900 dark:text-cream-100 group-hover:text-gold-600 dark:group-hover:text-gold-400 transition-colors duration-200">
            {book.bookName}
          </h2>
          <div class="mt-4 text-cream-500 dark:text-cream-500 text-sm flex items-center transition-colors duration-300">
            Lore this way
            <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 group-hover:text-gold-500 dark:group-hover:text-gold-400 transition-all duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>

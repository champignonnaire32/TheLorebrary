---
interface BreadcrumbItem {
  label: string;
  href?: string;
}
interface Props {
  items: BreadcrumbItem[];
}
const { items } = Astro.props;
---

<nav class="flex items-center flex-wrap gap-1.5 text-xs font-bold uppercase tracking-[0.12em] mb-3" aria-label="Breadcrumb">
  {items.map((item, i) => (
    <span class="flex items-center gap-1.5">
      {i > 0 && (
        <svg class="w-3 h-3 text-cream-500 dark:text-cream-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
        </svg>
      )}
      {item.href ? (
        <a
          href={item.href}
          class="text-cream-500 dark:text-cream-500 hover:text-gold-600 dark:hover:text-gold-400 transition-colors duration-150"
        >
          {item.label}
        </a>
      ) : (
        <span class="text-cream-800 dark:text-cream-200">{item.label}</span>
      )}
    </span>
  ))}
</nav>
<div class="mb-8 h-[2px] w-72" style="background: linear-gradient(to right, rgba(201,168,76,0.6) 75%, transparent)"></div>
